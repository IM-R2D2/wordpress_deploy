# Скопируйте в .env и заполните: cp .env.example .env
# Файл .env не коммитьте (см. .gitignore).
#
# Значения с пробелами, скобками, ! и т.п. оборачивайте в двойные кавычки:
#   WP_TITLE="Site WordPress (staging)"
#
# --- Режим деплоя (аргумент скрипта или переменная DEPLOY_ACTION) ---
# full       — один прогон: стек + один сайт (как раньше; по умолчанию).
# bootstrap  — только стек на ВМ (Nginx, MariaDB, PHP, WP-CLI), без WordPress.
# site       — ещё один сайт: свой домен, каталог, БД, vhost (после bootstrap).
# Примеры:
#   sudo ./deploy.sh bootstrap
#   sudo DEPLOY_ACTION=site DOMAIN=client2.example.com ./deploy.sh site
# DEPLOY_ACTION=full
#
# --- Несколько сайтов и .env ---
# Один запуск deploy читает ОДИН файл (по умолчанию ./.env) или тот, что в DEPLOY_ENV_FILE.
# Для разных доменов и разных админов WordPress заведите ОТДЕЛЬНЫЙ env на каждый сайт, например:
#   env/client-a.env   → DOMAIN, WP_ADMIN_USER, WP_ADMIN_EMAIL, WP_TITLE, CREDS_FILE=...
#   env/client-b.env   → другие значения
# Запуск:
#   sudo DEPLOY_ENV_FILE=/path/to/wordpress_deploy/env/client-a.env ./deploy.sh site
# В каждом файле свои WP_ADMIN_* (и при желании свой DB_NAME / WEB_ROOT). Пустой WP_ADMIN_PASS
# по-прежнему даёт автогенерацию; итог записывается в CREDS_FILE этого файла.

# --- Домен и пути ---
DOMAIN=localhost
WEB_ROOT=/var/www/wordpress
# Для DEPLOY_ACTION=site без WEB_ROOT каталог будет /var/www/sites/${DOMAIN}
# SITE_SLUG — имя файлов Nginx/ssl (по умолчанию из DOMAIN, напр. example-com)
# SITE_SLUG=

# --- MariaDB (чувствительные данные) ---
# Оставьте DB_PASS пустым — сгенерируется при деплое и попадёт в CREDS_FILE.
DB_NAME=wordpress
DB_USER=wordpress
DB_PASS=

# --- WordPress при установке ---
WP_TITLE="Site WordPress (staging)"
WP_ADMIN_USER=admin
# Оставьте WP_ADMIN_PASS пустым — сгенерируется при деплое.
WP_ADMIN_PASS=
WP_ADMIN_EMAIL=admin@example.local
# Локаль ядра WP, например: fr_CA, en_CA (необязательно)
WP_LOCALE=

# --- TLS и прочее ---
# 1 = только HTTP (без редиректа на HTTPS и без самоподписанного сертификата)
SKIP_SSL=0
SELF_SIGNED_DAYS=825

# Куда записать сводку паролей после деплоя (права 600)
# Для site по умолчанию: /root/wp-credentials-${SITE_SLUG}.txt
CREDS_FILE=/root/wordpress-staging-credentials.txt

# Первый vhost site: убрать default Nginx (0 = не трогать; на первом сайте можно 1)
# REMOVE_NGINX_DEFAULT=0
# Переустановка в тот же WEB_ROOT (опасно): FORCE_SITE_REINSTALL=1

# Необязательно: путь к .env, если запускаете не из каталога со скриптом
# DEPLOY_ENV_FILE=/path/to/.env
